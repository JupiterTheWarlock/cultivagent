{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "clear|startup|resume",
        "hooks": [
          { "type": "command", "command": "node __CULTIVAGENT_PLUGIN_ROOT__/scripts/hook.mjs session_start", "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node __CULTIVAGENT_PLUGIN_ROOT__/scripts/hook.mjs user_prompt_submit", "timeout": 8 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node __CULTIVAGENT_PLUGIN_ROOT__/scripts/hook.mjs stop", "timeout": 10 },
          { "type": "command", "command": "node __CULTIVAGENT_PLUGIN_ROOT__/scripts/session-collector.mjs --lookback-minutes 60 --batch-size 10", "timeout": 20 }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node __CULTIVAGENT_PLUGIN_ROOT__/scripts/hook.mjs pre_compact", "timeout": 10 }
        ]
      }
    ]
  }
}
